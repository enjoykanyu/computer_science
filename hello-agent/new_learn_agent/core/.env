# AI Agent 配置文件
# 请将此文件复制为 .env 并根据需要修改

# ========================================
# Ollama配置（推荐，本地免费运行）
# ========================================
USE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:0.6b
# 可选模型: deepseek-r1:8b, qwen3:1.7b, qwen3:0.6b

# ========================================
# OpenAI配置（可选，需要API密钥）
# ========================================
# USE_OLLAMA=false
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4

# ========================================
# Tavily API配置（景点搜索功能）
# ========================================
# 获取免费密钥: https://tavily.com/
TAVILY_API_KEY=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

# .env file
MODELSCOPE_API_KEY="your-modelscope-api-key"
